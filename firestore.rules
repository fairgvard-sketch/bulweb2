rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Analytics tracker writes from public pages (no auth needed)
    match /_visits/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Menu categories and items — public read, admin write
    match /_categories/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /hot-drinks/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /cold-drinks/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /sandwiches/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /pastries/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /filled/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /tartlets/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /cakes/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /ice-cream/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /alcohol/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /friday/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /shop/{doc}    { allow read: if true; allow write: if request.auth != null; }
    match /badges/{doc}  { allow read: if true; allow write: if request.auth != null; }
    match /popups/{doc}  { allow read: if true; allow write: if request.auth != null; }

    // Everything else — only authenticated admin
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
